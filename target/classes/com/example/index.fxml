<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
    fx:controller="com.example.Controllers.Index">

    <!-- LEFT: Templates -->
    <left>
        <VBox spacing="10" prefWidth="200" style="-fx-padding: 10;">
            <Label text="Templates"/>

            <ListView fx:id="templateList" VBox.vgrow="ALWAYS"/>

            <HBox spacing="10">
                <Button text="Add" onAction="#handleAdd"/>
                <Button text="Delete" onAction="#handleDelete"/>
            </HBox>
        </VBox>
    </left>

    <!-- CENTER: Preview -->
    <center>
        <VBox spacing="10" style="-fx-padding: 10;">
            <Label text="Preview"/>

            <TreeView fx:id="treeView" VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>

    <!-- BOTTOM: Action -->
    <bottom>
        <HBox spacing="10" style="-fx-padding: 10; -fx-alignment: center-right;">
            <Button text="Create Structure" onAction="#handleCreate"/>
        </HBox>
    </bottom>

</BorderPane>