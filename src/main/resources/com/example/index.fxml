<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.example.Controllers.Index">

    <!-- TOP HEADER -->
    <HBox spacing="10" style="-fx-padding: 10; -fx-alignment: center-left;">

        <!-- ICON -->
        <ImageView fitHeight="50" fitWidth="50">
            <image>
                <Image url="@icons/foldergen.png"/>
            </image>
        </ImageView>

        <!-- TITLE + INSTRUCTIONS -->
        <VBox spacing="2">
            <Label text="FolderGen : Folder Structure Generator"
                   style="-fx-font-size: 20px; -fx-font-weight: bold;" />

            <Label text="Create templates, preview structure, and generate folders"
                   style="-fx-font-size: 15px; -fx-text-fill: #9d9c9c;" />
        </VBox>
    </HBox>

    <BorderPane VBox.vgrow="ALWAYS">

        <!-- LEFT: Templates -->
        <left>
            <VBox spacing="10" prefWidth="200" style="-fx-padding: 10;">
                <Label text="Templates"/>

                <ListView fx:id="templateList" VBox.vgrow="ALWAYS"/>

                <HBox spacing="10">
                    <Button text="Add" onAction="#handleAdd"/>
                    <Button text="Delete" onAction="#handleDelete"/>
                </HBox>
            </VBox>
        </left>

        <!-- CENTER: Preview -->
        <center>
            <VBox spacing="10" style="-fx-padding: 10;">
                <Label text="Preview"/>

                <TreeView fx:id="treeView" VBox.vgrow="ALWAYS"/>
            </VBox>
        </center>

        <!-- BOTTOM: Action -->
        <bottom>
            <HBox spacing="10" style="-fx-padding: 10; -fx-alignment: center-right;">
                <Button text="Create Structure" onAction="#handleCreate"/>
            </HBox>
        </bottom>

    </BorderPane>

</VBox>